# Secrets — MUST never be committed/pushed (security audit S1/S2).
# The Android signing keystore + its password, and any local machine paths.
android/keystore.properties
android/local.properties
android/**/keystore.properties
*.keystore
*.jks
release.keystore

# Build output / caches
android/.gradle/
android/build/
android/app/build/
android/app/src/*/_beta_web_bak/
__pycache__/
*.pyc
.venv/
tiles_cache/
logs/

# Large runtime assets (pulled/synced, not source)
android/app/src/main/assets/web/pyodide/
ios/App/web/
web/pyodide/

# OS cruft
.DS_Store
Thumbs.db

# --- додано автоматично ---
node_modules/
*.apk
.DS_Store
sitl/ArduCopter.exe
*.exe

# --- open-source prep ---
# Build/run logs and generated outputs (not source)
*.log
exports/
# SITL third-party runtime (Cygwin DLLs) + local server config — download/build separately
sitl/*.dll
sitl/_vps_Caddyfile
# iOS build artifacts + Xcode user state
ios/build/
ios/**/xcuserdata/
*.xcuserstate
# Android: keep native source only — the web bundle + Pyodide are synced from web-stable/
# at build time (not source), and the gradle build output is generated.
android/app/src/main/assets/web/
android/app/src/main/assets/engine/
android/app/build/
android/build/
android/.gradle/
android/local.properties
# Local, gitignored runtime config (real server URL etc.) — see *.example
config.local.js
